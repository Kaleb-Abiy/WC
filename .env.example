# Telegram
TELEGRAM_BOT_TOKEN=put-your-botfather-token-here
# Comma-separated Telegram user ids who can run admin commands.
ADMIN_IDS=123456789

# Database (SQLite for dev; swap for postgresql+psycopg://... in prod)
DATABASE_URL=sqlite:///wcsweep.db

# Results provider (Phase 2 — not required for the manual MVP)
FOOTBALL_DATA_API_KEY=
# The poller runs once daily at this local time / timezone.
RESULTS_POLL_TIME=06:00
RESULTS_POLL_TZ=Africa/Addis_Ababa

# Game rules
ENTRY_AMOUNT=10
CURRENCY=USD
TEAMS_PER_PLAYER=5   # 48 teams / 5 = max 9 players
KO_PENALTY_AS_DRAW=false
DRAFT_TURN_SECONDS=43200
TIMEZONE=UTC

# Optional: announce draft turns / winners to a group chat
GROUP_CHAT_ID=
